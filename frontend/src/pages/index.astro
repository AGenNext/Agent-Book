---
// Ultimate RAG - Main Page (Astro)
// Full UI: Chat + Knowledge Graph + Editor + Search
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ultimate RAG</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/fabric@6.0.0/dist/fabric.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    .glass { background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); }
    .dark .glass { background: rgba(15,23,42,0.9); }
  </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
  <div class="h-screen flex flex-col">
    
    <!-- Header -->
    <header class="h-14 glass border-b flex items-center px-4 justify-between">
      <h1 class="text-xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
        Ultimate RAG
      </h1>
      <div class="flex gap-2 text-sm text-gray-500">
        <span>SurrealDB</span>
        <span>•</span>
        <span>Astro</span>
      </div>
    </header>
    
    <!-- Main Content -->
    <main class="flex-1 flex overflow-hidden">
      
      <!-- Sidebar -->
      <aside class="w-64 border-r p-4 overflow-y-auto">
        <div class="space-y-4">
          <button onclick="showTab('chat')" class="w-full p-3 text-left rounded-lg bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 font-medium">
            💬 Chat
          </button>
          <button onclick="showTab('graph')" class="w-full p-3 text-left rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800">
            🕸️ Knowledge Graph
          </button>
          <button onclick="showTab('search')" class="w-full p-3 text-left rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800">
            🔍 Search
          </button>
          <button onclick="showTab('documents')" class="w-full p-3 text-left rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800">
            📄 Documents
          </button>
        </div>
        
        <!-- Stats -->
        <div class="mt-8 p-4 bg-gray-100 dark:bg-gray-800 rounded-lg">
          <h3 class="font-medium mb-2">Stats</h3>
          <div class="text-sm text-gray-500 space-y-1">
            <div>Chunks: <span id="stat-chunks">0</span></div>
            <div>Entities: <span id="stat-entities">0</span></div>
            <div>Documents: <span id="stat-docs">0</span></div>
          </div>
        </div>
      </aside>
      
      <!-- Chat Tab -->
      <section id="tab-chat" class="flex-1 flex flex-col">
        <div id="messages" class="flex-1 overflow-y-auto p-4 space-y-4">
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-white text-sm">🤖</div>
            <div class="bg-white dark:bg-gray-800 rounded-2xl p-4 max-w-lg shadow-sm">
              <p class="text-sm">Hi! I'm your AI assistant. Ask me anything about your documents.</p>
            </div>
          </div>
        </div>
        
        <!-- Input -->
        <div class="p-4 border-t">
          <div class="flex gap-2">
            <input 
              id="chat-input" 
              type="text" 
              placeholder="Ask a question..." 
              class="flex-1 p-3 rounded-lg border bg-white dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500"
              onkeydown="if(event.key==='Enter')sendMessage()"
            />
            <button onclick="sendMessage()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
              Send
            </button>
          </div>
        </div>
      </section>
      
      <!-- Graph Tab -->
      <section id="tab-graph" class="flex-1 hidden">
        <canvas id="graph-canvas" class="w-full h-full"></canvas>
      </section>
      
      <!-- Search Tab -->
      <section id="tab-search" class="flex-1 p-4 hidden">
        <div class="max-w-2xl mx-auto">
          <input 
            id="search-input" 
            type="text" 
            placeholder="Search documents..." 
            class="w-full p-4 rounded-lg border bg-white dark:bg-gray-800 text-lg"
            onkeydown="if(event.key==='Enter')doSearch()"
          />
          <div id="search-results" class="mt-4 space-y-2"></div>
        </div>
      </section>
      
      <!-- Documents Tab -->
      <section id="tab-documents" class="flex-1 p-4 hidden">
        <div class="max-w-2xl mx-auto">
          <div class="flex gap-4 mb-4">
            <button onclick="uploadFile()" class="px-4 py-2 bg-green-600 text-white rounded-lg">
              📤 Upload File
            </button>
            <button onclick="indexFolder()" class="px-4 py-2 bg-purple-600 text-white rounded-lg">
              📁 Index Folder
            </button>
          </div>
          <div id="document-list" class="space-y-2"></div>
        </div>
      </section>
      
    </main>
  </div>
  
  <script>
    // Tab switching
    function showTab(tab) {
      ['chat','graph','search','documents'].forEach(t => {
        document.getElementById('tab-'+t).classList.toggle('hidden', t !== tab);
      });
      
      if (tab === 'graph') initGraph();
    }
    
    // Chat
    async function sendMessage() {
      const input = document.getElementById('chat-input');
      const msg = input.value.trim();
      if (!msg) return;
      
      // Add user message
      addMessage('user', msg);
      input.value = '';
      
      // Send to API
      try {
        const res = await fetch('/api/query', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({query: msg})
        });
        const data = await res.json();
        
        // Add AI response
        addMessage('assistant', data.response);
      } catch(e) {
        addMessage('error', 'Failed to connect to backend');
      }
    }
    
    function addMessage(role, content) {
      const container = document.getElementById('messages');
      const div = document.createElement('div');
      div.className = 'flex gap-3';
      div.innerHTML = `
        ${role === 'user' 
          ? `<div class="w-8 h-8 rounded-full bg-gray-300 flex items-center justify-center text-sm">👤</div>
             <div class="bg-gray-100 dark:bg-gray-800 rounded-2xl p-4 max-w-lg">${content}</div>`
          : `<div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-white text-sm">🤖</div>
             <div class="bg-white dark:bg-gray-800 rounded-2xl p-4 max-w-lg shadow-sm" contenteditable="true">${content}</div>
             <button onclick="saveEdit(this)" class="text-xs text-green-600 ml-2">Save</button>`
        }
      `;
      container.appendChild(div);
      container.scrollTop = container.scrollHeight;
    }
    
    // Save inline edit
    function saveEdit(btn) {
      const content = btn.previousElementSibling.innerText;
      fetch('/api/save', {method:'POST', body:JSON.stringify({content})});
      btn.innerText = '✓ Saved';
    }
    
    // Knowledge Graph (fabric.js)
    let canvas;
    function initGraph() {
      if (canvas) return;
      
      const el = document.getElementById('graph-canvas');
      canvas = new fabric.Canvas('graph-canvas', {
        width: el.offsetWidth,
        height: el.offsetHeight
      });
      
      // Sample nodes
      const nodes = ['Document', 'Chunk', 'Entity', 'Relation', 'Chat'];
      nodes.forEach((n, i) => {
        const rect = new fabric.Circle({
          left: 100 + i * 120,
          top: 100,
          radius: 30,
          fill: i < 2 ? '#3b82f6' : '#8b5cf6',
          originX: 'center',
          originY: 'center'
        });
        const text = new fabric.Text(n, {
          left: 100 + i * 120,
          top: 150,
          fontSize: 12,
          originX: 'center'
        });
        canvas.add(rect, text);
      });
    }
    
    // Search
    async function doSearch() {
      const query = document.getElementById('search-input').value;
      const res = await fetch('/api/query?query=' + encodeURIComponent(query));
      const data = await res.json();
      
      document.getElementById('search-results').innerHTML = 
        data.results?.map(r => `<div class="p-3 bg-white dark:bg-gray-800 rounded">${r.content}</div>`).join('') || '';
    }
    
    // Documents
    async function uploadFile() {
      const input = document.createElement('input');
      input.type = 'file';
      input.onchange = async (e) => {
        const file = e.target.files[0];
        const formData = new FormData();
        formData.append('file', file);
        await fetch('/api/index', {method:'POST', body:formData});
        alert('Indexed: ' + file.name);
      };
      input.click();
    }
    
    async function indexFolder() {
      const path = prompt('Enter folder path:');
      if(path) {
        await fetch('/api/index', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body:JSON.stringify({path, recursive:true})
        });
      }
    }
    
    // Load stats
    async function loadStats() {
      try {
        const res = await fetch('/api/stats');
        const data = await res.json();
        document.getElementById('stat-chunks').innerText = data.chunks || 0;
        document.getElementById('stat-entities').innerText = data.entities || 0;
        document.getElementById('stat-docs').innerText = data.documents || 0;
      } catch(e) {}
    }
    
    loadStats();
  </script>
</body>
</html>